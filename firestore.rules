rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn() && currentUser().data.role == role;
    }

    match /users/{uid} {
      allow read: if owns(uid) || hasRole('admin');
      allow create, update: if owns(uid);
      allow delete: if false;
    }

    match /studentDirectory/{uid} {
      allow read: if owns(uid) || hasRole('parent') || hasRole('admin');
      allow create, update: if owns(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /studentApprovals/{uid} {
      allow read: if owns(uid) || hasRole('parent') || hasRole('admin');
      allow create, update: if hasRole('parent') || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    match /studyLogs/{uid}/logs/{logId} {
      allow read, create: if owns(uid);
      allow update, delete: if false;
    }

    match /notes/{uid}/items/{noteId} {
      allow read, create, update, delete: if owns(uid);
    }
  }
}
