rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if owns(uid);
      allow create, update: if owns(uid);
      allow delete: if false;
    }

    match /studentDirectory/{uid} {
      allow read: if signedIn();
      allow create, update: if owns(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /studyLogs/{uid}/logs/{logId} {
      allow read, create: if owns(uid);
      allow update, delete: if false;
    }

    match /notes/{uid}/items/{noteId} {
      allow read, create, update, delete: if owns(uid);
    }
  }
}
